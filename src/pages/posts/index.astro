---
import BlogLayout from "../../layouts/BlogLayout.astro";
import "../../assets/blog-list.css";

const posts = Object.entries(
  import.meta.glob("./*.md", { eager: true })
)
  .map(([path, post]) => {
    const slug = path.split("/").pop().replace(".md", "");

    return {
      slug,
      ...post.frontmatter
    };
  })
  .filter(post => !post.draft)
  .sort((a, b) => new Date(b.date) - new Date(a.date));

const formatDate = (dateStr) => {
  return new Date(dateStr).toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'short',
    day: 'numeric'
  });
};

const getAuthors = (authorValue) => {
  if (!authorValue) return [];
  if (Array.isArray(authorValue)) return authorValue;
  return [authorValue];
};
---

<BlogLayout frontmatter={{ title: "Posts" }}>
  <header class="posts-header">
    <h1>Writeups</h1>
    <p class="header-subtitle">List of all writeups/research blogs written by ResetSec members...</p>
  </header>

  <div class="post-grid">
    {posts.map(post => {
      const authors = getAuthors(post.author);
      const categoryClass = `category-${post.category?.toLowerCase() || 'none'}`;
      const difficultyClass = `diff-${post.difficulty?.toLowerCase() || 'none'}`;

      return (
        <article class="post-card">
          <div class="post-content">
            <div class="post-header-meta">
              <div class="meta-left">
                {post.event && (
                  <span class="event-name" title="Event">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 15s1-1 4-1 5 2 8 2 4-1 4-1V3s-1 1-4 1-5-2-8-2-4 1-4 1z"/><line x1="4" y1="22" x2="4" y2="15"/></svg>
                    <span>{post.event}</span>
                  </span>
                )}
                <span class="post-date" title="Publish Date">
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                  <span>{formatDate(post.date)}</span>
                </span>
              </div>

              <div class="chip-container">
                {post.category && (
                  <span class={`chip category-chip ${categoryClass}`}>
                    {post.category}
                  </span>
                )}
                {post.difficulty && (
                  <span class={`chip difficulty-chip ${difficultyClass}`}>
                    {post.difficulty}
                  </span>
                )}
              </div>
            </div>

            <h2 class="post-title">
              <a href={`/posts/${post.slug}`}>{post.title}</a>
            </h2>

            {post.description && (
              <p class="post-description">{post.description}</p>
            )}

            {authors.length > 0 && (
              <div class="post-authors" title="Authors">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                <div class="author-list">
                  {authors.map(author => (
                    <span class="author-name">{author}</span>
                  ))}
                </div>
              </div>
            )}

            {post.tags && post.tags.length > 0 && (
              <div class="tags-list">
                {post.tags.map(tag => (
                  <span class="tag-item">#{tag}</span>
                ))}
              </div>
            )}
          </div>
        </article>
      );
    })}
  </div>
</BlogLayout>
